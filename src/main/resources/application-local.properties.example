# ==========================================
# CONFIGURACIÓN LOCAL (SENSIBLE)
# Este archivo está ignorado en Git y contiene tus credenciales personales.
# ==========================================

# Puerto de ejecución local
server.port=8080

# Configuración de MongoDB (Local)
spring.data.mongodb.uri=mongodb://localhost:27017
spring.data.mongodb.database=restock-bd

# Configuración de Firebase Cloud Messaging
FIREBASE_PROJECT_ID=restock-experimentos
FIREBASE_SERVICE_ACCOUNT_